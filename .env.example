# Amazing Marvin MCP — environment variables
# Copy this file to .env and fill in your values.

# Standard API token (required)
AMAZING_MARVIN_API_KEY=

# Full-access token (required for /api/doc/* endpoints — task edit, smart-list CRUD, habits update)
AMAZING_MARVIN_FULL_ACCESS_TOKEN=

# CouchDB / Cloudant direct access (optional — enables list_smart_lists and other find-based tools)
# Available in Marvin: Strategies -> API -> Sync
AMAZING_MARVIN_DB_URI=
AMAZING_MARVIN_DB_NAME=
AMAZING_MARVIN_DB_USER=
AMAZING_MARVIN_DB_PASSWORD=
